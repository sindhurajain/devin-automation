# GitHub settings
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=sindhurajain/superset
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Devin settings
DEVIN_API_KEY=cog_your_service_user_token_here
DEVIN_ORG_ID=org_your_org_id_here
DEVIN_REPO_URLS=https://github.com/sindhurajain/superset
DEVIN_CREATE_AS_USER_ID=user_abc123def456  # optional
DEVIN_MODE=normal

# Database settings
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/devin_automation
LOG_FILE=automation.log
