# GitHub settings
GITHUB_TOKEN=ghp_<your-github-token>  # GitHub PAT with repo access for comments and issues
GITHUB_REPO=<your-github-owner>/<your-github-repo>  # example: sindhurajain/superset
GITHUB_WEBHOOK_SECRET=<your-webhook-secret>  # must match the webhook secret configured on the Superset fork

# Devin settings
DEVIN_API_KEY=<your-devin-api-key>  # Devin service user token; member role is sufficient, usually starts with cog_
DEVIN_ORG_ID=<your-devin-org-id>  # your Devin org ID, usually starts with org-
DEVIN_REPO_URLS=https://github.com/<your-github-owner>/<your-github-repo>  # example: https://github.com/sindhurajain/superset
DEVIN_MODE=normal

# Database settings
POSTGRES_PASSWORD=<your-postgres-password>
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/devin_automation
LOG_FILE=automation.log
